<style>
  @import url("https://fonts.cdnfonts.com/css/alte-haas-grotesk");

  :root {
    --black: #231f20;
    --ivory: #fffff0;
    --grid-gray: #cccdc8;
    --os-gray: #7a7a7a;
    --grid-line: rgba(255, 255, 255, 0.5);
    --accent: {{accent}};
    --variant-yellow: #fedd00;
