<style>
  @import url('https://fonts.cdnfonts.com/css/alte-haas-grotesk');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --black: #231F20;
    --ivory: #FFFFF0;
    --mint: #00C9A7;
    --deep: #1A1A2E;
  }

  body {
    font-family: 'Alte Haas Grotesk', Arial, sans-serif;
    background: var(--deep);
    color: var(--ivory);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  .mono { font-family: 'JetBrains Mono', monospace; }

  /* === HERO === */
  .hero {
    text-align: center;
    padding: 5rem 2rem 3rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mint);
    border: 2px solid var(--mint);
    border-radius: 100px;
    padding: 0.35rem 1.2rem;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.1;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .hero h1 .accent { color: var(--mint); }
  .hero p {
    font-size: 1.15rem;
    color: rgba(255,255,240,0.7);
    max-width: 600px;
    margin: 0 auto;
  }

  /* === STATS BAR === */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 2rem;
    margin: 0 auto 3rem;
    max-width: 800px;
    border-top: 1px solid rgba(255,255,240,0.1);
    border-bottom: 1px solid rgba(255,255,240,0.1);
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--mint);
  }
  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,240,0.5);
    margin-top: 0.25rem;
  }

  /* === CAMPAIGN CARDS === */
  .campaigns {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .campaign-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: rgba(255,255,240,0.04);
    border: 1px solid rgba(255,255,240,0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
  }
  .campaign-card:hover {
    border-color: var(--mint);
    transform: translateY(-2px);
  }
  .campaign-card.featured {
    border-color: var(--mint);
    background: rgba(0,201,167,0.04);
  }
  .campaign-card.featured .card-rank { background: var(--mint); color: var(--deep); }

  .card-screenshot {
    position: relative;
    overflow: hidden;
  }
  .card-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }
  .campaign-card:hover .card-screenshot img {
    transform: scale(1.03);
  }
  .card-rank {
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: rgba(255,255,240,0.15);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 0.85rem;
  }

  .card-body {
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .card-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 0.5rem;
  }
  .card-body h2 {
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .card-body .desc {
    color: rgba(255,255,240,0.6);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .metric {
    background: rgba(255,255,240,0.05);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
  }
  .metric-val {
    font-size: 1.3rem;
    font-weight: 900;
  }
  .metric-val.mint { color: var(--mint); }
  .metric-val.gold { color: #FEDD00; }
  .metric-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,240,0.4);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--mint);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: gap 0.2s;
  }
  .card-link:hover { gap: 0.8rem; }
  .card-link .arrow { font-size: 1.1rem; transition: transform 0.2s; }
  .card-link:hover .arrow { transform: translateX(3px); }

  /* === ORGANIC SECTION === */
  .organic-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-header h2 {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
  }
  .section-header p {
    color: rgba(255,255,240,0.5);
    font-size: 0.95rem;
  }

  .organic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .organic-card {
    background: rgba(255,255,240,0.04);
    border: 1px solid rgba(255,255,240,0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
    text-decoration: none;
    color: var(--ivory);
    display: block;
  }
  .organic-card:hover {
    border-color: rgba(255,255,240,0.25);
    transform: translateY(-2px);
  }
  .organic-card img {
    width: 100%;
    aspect-ratio: 1200/630;
    object-fit: cover;
    display: block;
  }
  .organic-card-body {
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .organic-card h3 {
    font-size: 1rem;
    font-weight: 700;
  }
  .organic-card .organic-stats {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: rgba(255,255,240,0.5);
  }
  .organic-card .organic-stats strong {
    color: var(--mint);
    font-weight: 700;
  }

  /* === CTA === */
  .cta-section {
    text-align: center;
    padding: 4rem 2rem 5rem;
    max-width: 650px;
    margin: 0 auto;
  }
  .cta-section h2 {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 0.75rem;
  }
  .cta-section p {
    color: rgba(255,255,240,0.6);
    margin-bottom: 2rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--mint);
    color: var(--deep);
    font-weight: 800;
    font-size: 1rem;
    padding: 0.9rem 2.5rem;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,201,167,0.3);
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .campaign-card { grid-template-columns: 1fr; }
    .card-body { padding: 1.5rem; }
    .stats-bar { gap: 1.5rem; flex-wrap: wrap; }
    .hero { padding: 3rem 1.5rem 2rem; }
    .organic-card-body { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
  }
</style>

