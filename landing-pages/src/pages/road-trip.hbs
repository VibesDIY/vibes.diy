<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=optional');

  :root {
    --bg: #17100d;
    --surface: #231913;
    --ink: #f8e3ca;
    --muted: #d2b89d;
    --line: #3a2d25;
    --brand: #f2a86b;
    --brand-strong: #c97033;
    --pill: #6f3e1f;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--ink);
    line-height: 1.55;
    background: radial-gradient(circle at 10% 0, #302017 0, var(--bg) 40%), var(--bg);
  }

  a { color: inherit; text-decoration: none; }

  .page { max-width: 980px; margin: 0 auto; padding: 0 1.25rem 4rem; }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
    font-size: 0.85rem;
  }

  .brand { font-weight: 700; color: var(--brand); }
  .path { color: var(--muted); }

  .hero { padding: 3.1rem 0 2.1rem; }
  .eyebrow {
    display: inline-block;
    background: var(--pill);
    color: #ffd8b2;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  h1 {
    margin: 0;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
  }

  .lead {
    margin: 1rem 0 1.35rem;
    color: var(--muted);
    max-width: 62ch;
    font-size: 1.03rem;
  }

  .primary-cta {
    display: inline-block;
    background: var(--brand);
    color: #2a170d;
    font-weight: 800;
    padding: 0.82rem 1.2rem;
    border-radius: 0.62rem;
  }

  .primary-cta:hover { background: #ffc795; }

  .hero-img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 0.9rem;
    margin: 1.6rem 0 0;
    border: 1px solid var(--line);
  }

  .hero-img-credit { display: block; text-align: right; font-size: 0.65rem; color: var(--muted); margin: 0.3rem 0 0; }

  .proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0 0 2rem;
  }

  .proof-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    padding: 0.95rem;
  }

  .proof-card strong { display: block; margin-bottom: 0.3rem; }
  .proof-card span { color: var(--muted); font-size: 0.86rem; }

  .section-title { margin: 0 0 0.9rem; font-size: 1.1rem; font-weight: 800; }

  .apps-grid { display: grid; gap: 0.9rem; }

  .app-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    padding: 1rem;
  }

  .app-head { display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 0.3rem; }
  .app-index { color: var(--brand); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.12em; }
  .app-title { margin: 0; font-size: 1.06rem; font-weight: 800; }
  .app-desc { margin: 0; color: var(--muted); font-size: 0.92rem; }

  .actions { margin-top: 0.82rem; display: flex; align-items: center; gap: 0.78rem; flex-wrap: wrap; }

  .open-btn {
    border: 1px solid var(--brand);
    border-radius: 0.55rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: #ffe5ca;
  }

  .open-btn:hover { background: rgba(242, 168, 107, 0.1); }

  .minor-link {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .closing {
    margin-top: 2rem;
    background: #f2a86b;
    color: #2f1708;
    border-radius: 0.95rem;
    padding: 1.3rem;
  }

  .closing h2 { margin: 0 0 0.45rem; font-size: 1.2rem; }
  .closing p { margin: 0 0 0.9rem; }

  @media (max-width: 760px) {
    .proof { grid-template-columns: 1fr; }
  }
</style>

