<style>
  /* Field Notes — late-2000s personal blog */

  :root {
    --ink: #1a1a22;
    --paper: #f4ede0;
    --paper-soft: #efe7d6;
    --rule: #c9bfa9;
    --muted: #6b6555;
    --accent: #1f5f5b;     /* deep teal */
    --accent-soft: #b9d4cf;
    --rust: #a04a2c;
    --tag-bg: #e6dec8;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 8% 6%, rgba(31, 95, 91, 0.05) 0, transparent 40%),
      radial-gradient(circle at 92% 90%, rgba(160, 74, 44, 0.05) 0, transparent 40%),
      var(--paper);
    color: var(--ink);
    font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
    font-size: 17px;
    line-height: 1.65;
  }

  ::selection { background: var(--accent-soft); color: var(--ink); }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  a:visited { color: #5a3d6e; }
  a:hover { color: var(--rust); }

  /* masthead */
  .masthead {
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    padding: 28px 24px 22px;
    text-align: center;
  }
  .mast-kicker {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 8px;
  }
  .mast-title {
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-weight: 400;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  .mast-tagline {
    font-style: italic;
    color: var(--muted);
    margin: 0;
    font-size: 16px;
  }
  .mast-nav {
    margin-top: 16px;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .mast-nav a {
    margin: 0 10px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .mast-nav a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* main column */
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 24px 64px;
  }

  /* About / lede */
  .lede {
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 36px;
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 18px;
  }
  .lede em { color: var(--rust); font-style: italic; }

  /* section heading */
  .section-head {
    margin: 56px 0 18px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 10px;
  }
  .section-head h2 {
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-weight: 400;
    font-size: 28px;
    margin: 0 0 4px;
    letter-spacing: -0.005em;
  }
  .section-head .deck {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  /* posts */
  article.post {
    margin: 0 0 44px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--rule);
  }
  article.post:last-child { border-bottom: none; }
  .post-meta {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 6px;
  }
  .post-meta .dot { margin: 0 8px; opacity: 0.6; }
  .post-meta a { color: var(--muted); text-decoration: none; border-bottom: 1px dotted var(--rule); }
  .post-meta a:hover { color: var(--accent); border-bottom-color: var(--accent); }

  .post-title {
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.2;
    margin: 0 0 14px;
    letter-spacing: -0.005em;
  }
  .post-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid transparent; }
  .post-title a:hover { border-bottom-color: var(--accent); color: var(--accent); }

  .post-figure {
    margin: 0 0 16px;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
  }
  .post-figure a { display: block; }
  .post-figure img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    filter: saturate(0.82) contrast(0.95);
  }

  .post-body { margin: 0 0 14px; color: var(--ink); }

  .post-actions {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    margin: 0;
  }
  .post-actions a {
    margin-right: 16px;
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }
  .post-actions a:last-child { margin-right: 0; }
  .post-actions a.start-fresh {
    color: var(--rust);
    border-bottom-color: var(--rust);
    font-weight: 600;
  }
  .post-actions a.start-fresh:hover {
    background: var(--rust);
    color: var(--paper);
    border-bottom-color: var(--rust);
  }

  /* prompt screenshots — single hero or multi-take grid */
  .prompt-figures {
    display: grid;
    gap: 8px;
    margin: 0 0 16px;
    grid-template-columns: 1fr;
  }
  .prompt-figures.multi {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .prompt-figures a {
    display: block;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
    overflow: hidden;
  }
  .prompt-figures img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    filter: saturate(0.82) contrast(0.95);
    transition: filter 0.2s ease;
  }
  .prompt-figures a:hover img { filter: saturate(1) contrast(1.02); }

  /* prompt list variants — multiple takes inline */
  .takes-line {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 10px;
  }
  .takes-line a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-soft);
    margin-right: 14px;
  }
  .takes-line a:hover { border-bottom-color: var(--accent); }

  /* tags */
  .tags {
    margin: 14px 0 0;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tags .label {
    color: var(--muted);
    margin-right: 6px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .tags a {
    display: inline-block;
    background: var(--tag-bg);
    color: var(--ink);
    padding: 2px 9px;
    margin: 0 4px 4px 0;
    text-decoration: none;
    border: 1px solid transparent;
  }
  .tags a:hover { background: var(--accent-soft); }

  /* pull quote */
  .pull {
    margin: 60px 0;
    padding: 24px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    color: var(--ink);
  }
  .pull strong { font-style: normal; font-weight: 700; }
  .pull cite {
    display: block;
    margin-top: 14px;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* subscribe */
  .subscribe {
    margin: 56px 0 32px;
    padding: 28px 28px 24px;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
    text-align: center;
  }
  .subscribe h2 {
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-weight: 400;
    font-size: 24px;
    margin: 0 0 6px;
  }
  .subscribe p {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 15px;
  }
  .subscribe form {
    display: inline-flex;
    gap: 8px;
    max-width: 100%;
    flex-wrap: wrap;
    justify-content: center;
  }
  .subscribe input[type="email"] {
    padding: 10px 14px;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    font-family: Georgia, serif;
    font-size: 15px;
    min-width: 240px;
  }
  .subscribe input[type="email"]:focus { outline: 1px solid var(--accent); border-color: var(--accent); }
  .subscribe button[type="submit"] {
    padding: 10px 18px;
    background: var(--ink);
    color: var(--paper);
    border: 1px solid var(--ink);
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .subscribe button[type="submit"]:hover { background: var(--accent); border-color: var(--accent); }
  .featured-cta-response {
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
    min-height: 1em;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    letter-spacing: 0.06em;
  }
  .featured-cta-response.is-success { color: var(--accent); }
  .featured-cta-response.is-error { color: var(--rust); }

  /* sidebars-as-sections */
  .blogroll {
    margin: 48px 0 24px;
    padding: 24px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .blogroll h2 {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 14px;
  }
  .blogroll ul {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    column-gap: 32px;
  }
  .blogroll li {
    margin: 0 0 8px;
    font-size: 15px;
    break-inside: avoid;
  }
  .blogroll li a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--rule);
  }
  .blogroll li a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .blogroll li .desc { color: var(--muted); font-size: 13px; font-style: italic; }

  /* colophon */
  .colophon {
    margin: 40px 0 0;
    padding: 24px 0 0;
    border-top: 1px solid var(--rule);
    text-align: center;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .colophon p { margin: 0 0 6px; }
  .colophon a { color: var(--muted); text-decoration: none; border-bottom: 1px dotted var(--rule); }
  .colophon a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .ornament { color: var(--rule); margin: 0 12px; }

  @media (max-width: 540px) {
    .blogroll ul { columns: 1; }
    .post-title { font-size: 22px; }
  }
</style>

<header class="masthead">
  <p class="mast-kicker">Vibes DIY · Field Notes № 02</p>
  <h1 class="mast-title">Mood, Dreams &amp; Journals</h1>
  <p class="mast-tagline">Inner-life logging — daily check-ins, dream patterns, written reflections, and time-locked notes to your future self.</p>
  <nav class="mast-nav">
    <a href="#about">About</a>
    <a href="#picks">Picks</a>
    <a href="#prompts">Prompts</a>
    <a href="#subscribe">Subscribe</a>
    <a href="/featured-apps/">Index</a>
  </nav>
</header>

<main>

  <a id="about"></a>
  <p class="lede">
    A small, slow corner of the site for the apps people make to track their <em>inner</em> weather — moods, dreams, letters to themselves five Christmases out. None of these are products. All of them are vibes — built in an evening, for the few people who'll actually use them.
  </p>

  <div class="section-head">
    <h2>Field Picks</h2>
    <p class="deck">Classic vibes from the OG vibes.diy era · click through, clone, or remix</p>
  </div>

  <a id="picks"></a>
  {{#each classics}}
  <article class="post">
    <p class="post-meta">
      <span>{{date}}</span>
      <span class="dot">·</span>
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">{{category}}</a>
      <span class="dot">·</span>
      <span>by {{author}}</span>
    </p>
    <h3 class="post-title">
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">{{slug}}</a>
    </h3>
    <div class="post-figure">
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">
        <img src="https://{{slug}}--{{author}}.prod-v2.vibesdiy.net/screenshot.jpg" alt="{{slug}}" onerror="this.onerror=null; this.src='{{@root.assetPrefix}}images/og-preview.png';">
      </a>
    </div>
    <p class="post-body">{{description}}</p>
    <p class="post-actions">
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">Visit →</a>
