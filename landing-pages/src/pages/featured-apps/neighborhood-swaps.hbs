<script>
(function() {
  const INIT_FLAG = '__vibesMailchimpNewsletterAjax__';
  if (window[INIT_FLAG]) return;
  window[INIT_FLAG] = true;
  const JSONP_NAMESPACE = '__vibesMailchimpCallbacks__';
  if (!window[JSONP_NAMESPACE] || typeof window[JSONP_NAMESPACE] !== 'object') {
    window[JSONP_NAMESPACE] = {};
  }
  function clean(m) { return String(m).replace(/<[^>]*>/g,'').replace(/^\s*[01]\s*-\s*/,'').trim() || 'Something went wrong.'; }
  function jsonp(url, ms) {
    return new Promise((resolve, reject) => {
      const k = 'cb_' + Math.random().toString(36).slice(2);
      url.searchParams.set('c', JSONP_NAMESPACE + '.' + k);
      const s = document.createElement('script');
      s.src = url.toString();
      s.async = true;
      let done = false;
      const t = setTimeout(() => fin(new Error('Timeout')), ms);
      function fin(e, d) {
        if (done) return;
        done = true;
        clearTimeout(t);
        delete window[JSONP_NAMESPACE][k];
        s.remove();
        e ? reject(e) : resolve(d);
      }
      window[JSONP_NAMESPACE][k] = (d) => fin(null, d);
      s.onerror = () => fin(new Error('Network'));
      document.body.appendChild(s);
    });
  }
  function set(el, st, msg) {
    el.classList.remove('is-loading','is-success','is-error');
    el.textContent = msg;
    if (st) el.classList.add(st);
  }
  const form = document.getElementById('mc-embedded-subscribe-form');
  if (!(form instanceof HTMLFormElement)) return;
  const r = form.parentElement.querySelector('.featured-cta-response');
  const btn = form.querySelector('button[type="submit"]');
  let busy = false;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (busy) return;
    if (!form.checkValidity()) return form.reportValidity();
    busy = true; btn.disabled = true;
    set(r, 'is-loading', 'Sending …');
    try {
      const u = new URL(form.action);
      u.pathname = u.pathname.replace(/\/subscribe\/post\/?$/, '/subscribe/post-json');
      const fd = new FormData(form);
      for (const [k,v] of fd.entries()) {
        if (k === 'EMAIL' || k === 'SOURCE' || k.startsWith('b_')) u.searchParams.set(k, String(v));
      }
      const d = await jsonp(u, 10000);
      if (d && d.result === 'success') {
        set(r, 'is-success', 'Subscribed — check your inbox to confirm.');
        form.reset();
      } else {
        set(r, 'is-error', d && d.msg ? clean(d.msg) : 'Something went wrong.');
      }
    } catch(err) {
      set(r, 'is-error', 'Could not connect. Please try again.');
    } finally {
      busy = false; btn.disabled = false;
    }
  });
})();
</script>
