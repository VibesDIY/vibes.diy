    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }
  .prompt-figures a {
    display: block;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
    overflow: hidden;
  }
  .prompt-figures img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
