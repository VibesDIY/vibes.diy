    margin: 0 0 8px;
    font-size: 15px;
    break-inside: avoid;
  }
  .blogroll li a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--rule);
  }
  .blogroll li a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .blogroll li .desc { color: var(--muted); font-size: 13px; font-style: italic; }

  .colophon {
    margin: 40px 0 0;
    padding: 24px 0 0;
