  .prompt-figures a:hover img { filter: saturate(1) contrast(1.02) sepia(0); }

  .takes-line {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 10px;
  }
  .takes-line a {
