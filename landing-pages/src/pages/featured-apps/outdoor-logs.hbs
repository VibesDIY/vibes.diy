  }
  .post-title a { color: var(--ink); text-decoration: none; border-bottom: 1px solid transparent; }
  .post-title a:hover { border-bottom-color: var(--accent); color: var(--accent); }

  .post-body { margin: 0 0 14px; color: var(--ink); }

  .post-actions {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    margin: 0;
  }
  .post-actions a {
    margin-right: 16px;
    text-decoration: none;
