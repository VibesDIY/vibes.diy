    color: var(--muted);
  }
  .colophon p { margin: 0 0 6px; }
  .colophon a { color: var(--muted); text-decoration: none; border-bottom: 1px dotted var(--rule); }
  .colophon a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .ornament { color: var(--rule); margin: 0 12px; }

  @media (max-width: 540px) {
    .blogroll ul { columns: 1; }
    .post-title { font-size: 22px; }
  }
</style>

<header class="masthead">
  <p class="mast-kicker">Vibes DIY · Field Notes № 05 · Ranger Station</p>
  <h1 class="mast-title">Outdoor Adventure Logs</h1>
  <p class="mast-tagline">Field journals for the world outside — sunset timelapses, sound maps, stargazing logs, geocache hunts.</p>
  <nav class="mast-nav">
    <a href="#about">About</a>
    <a href="#prompts">Trail Logs</a>
    <a href="#subscribe">Subscribe</a>
    <a href="/featured-apps/">Index</a>
  </nav>
</header>

<main>

  <a id="about"></a>
  <p class="lede">
    A small <em>ranger-station bulletin</em> for the apps people make to record the world outside — sunsets aligned across seasons, ambient sound maps from the slow walk home, constellations logged on a clear night, geocaches signed under a rock. Birders keep life lists. Stargazers track meridians. None of these are products. All of them are vibes — built in an evening, carried on a phone, shared with the three friends who actually walk the trail with you.
  </p>

  <div class="section-head">
    <h2>Trail Logs &amp; Prompts</h2>
    <p class="deck">Pick one, fork it, or start a fresh take from the prompt itself</p>
  </div>

  <a id="prompts"></a>
  {{#each groups}}
  <article class="post">
    <p class="post-meta">
      <span>Log № {{numIdx @index}}</span>
      {{#if variants.[1]}}
      <span class="dot">·</span>
      <span>{{variants.length}} takes already exist</span>
      {{/if}}
    </p>
    <h3 class="post-title">{{title}}</h3>

    <div class="prompt-figures{{#if variants.[1]}} multi{{/if}}">
      {{#each variants}}
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}" aria-label="{{slug}} screenshot">
        <img src="https://{{slug}}--{{author}}.prod-v2.vibesdiy.net/screenshot.jpg" alt="{{slug}}" onerror="this.onerror=null; this.src='{{@root.assetPrefix}}images/og-preview.png';">
      </a>
      {{/each}}
    </div>

    <p class="post-body">{{description}}</p>

    {{#if variants.[1]}}
    <p class="takes-line">
      Existing takes:
      {{#each variants}}
      <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">{{slug}}</a>
      {{/each}}
    </p>
    {{else}}
    {{#with variants.[0]}}
    <p class="takes-line">
      One take so far: <a href="https://vibes.diy/vibe/{{author}}/{{slug}}">{{slug}}</a>
    </p>
    {{/with}}
    {{/if}}

    <p class="post-actions">
      {{#with variants.[0]}}
      <a href="https://vibes.diy/remix/{{author}}/{{slug}}?skipChat=true">Clone a take</a>
      <a href="https://vibes.diy/remix/{{author}}/{{slug}}">Remix it</a>
      {{/with}}
      <a class="start-fresh" href="https://vibes.diy/chat/prompt?prompt64={{prompt64 description}}">Start fresh from this prompt →</a>
    </p>

    {{#if tags}}
    <p class="tags">
      <span class="label">Tags</span>
      {{#each tags}}<a href="#">#{{this}}</a>{{/each}}
    </p>
    {{/if}}
  </article>
  {{/each}}

  <blockquote class="pull">
    "The audience is three hikers and a curious dog —<br>
    but the trail is real,<br>
    and anyone can ship a logbook in the time it takes to walk it."
    <cite>— Field Notes, № 05</cite>
  </blockquote>

  <a id="subscribe"></a>
  <section class="subscribe">
    <h2>Get the next batch in your inbox.</h2>
    <p>One email when a new round of trail logs ships. Plus the prompts behind them.</p>
    <form
      action="https://diy.us9.list-manage.com/subscribe/post?u=3336ce5a9fc731f6f88b5bcad&amp;id=1cca0fb28b&amp;f_id=007b69e1f0&amp;SOURCE={{source}}"
      method="post"
      id="mc-embedded-subscribe-form"
      name="mc-embedded-subscribe-form"
      target="_blank"
    >
      <input type="email" name="EMAIL" placeholder="you@somewhere.com" required aria-label="Email" autocomplete="email">
      <button type="submit" name="subscribe">Send me the trail notes</button>
      <input type="hidden" name="SOURCE" value="{{source}}">
      <div aria-hidden="true" style="position:absolute; left:-5000px;">
        <input type="text" name="b_3336ce5a9fc731f6f88b5bcad_1cca0fb28b" tabindex="-1" value="">
      </div>
    </form>
    <div class="featured-cta-response" aria-live="polite"></div>
  </section>

  <section class="blogroll">
    <h2>Blogroll · Field Notes from elsewhere on the site</h2>
    <ul>
      <li><a href="/featured-apps/garden-and-plants.html">Garden &amp; Plants</a><br><span class="desc">Bee gardens, herb encyclopedias, plant journals.</span></li>
      <li><a href="/featured-apps/photo-identifiers.html">Photo Identifiers</a><br><span class="desc">Snap a thing, name a thing.</span></li>
      <li><a href="/featured-apps/mood-and-journals.html">Mood, Dreams &amp; Journals</a><br><span class="desc">Inner-life logging.</span></li>
      <li><a href="/featured-apps/">All Categories</a><br><span class="desc">Every Field Note in one place.</span></li>
    </ul>
  </section>

  <footer class="colophon">
    <p>Field Notes № 05 · Outdoor Adventure Logs</p>
    <p>
      Set in Didot &amp; Georgia
      <span class="ornament">·</span>
      Posted April 29, 2026
      <span class="ornament">·</span>
      <a href="mailto:hello@vibes.diy">hello@vibes.diy</a>
    </p>
  </footer>

</main>

<script>
(function() {
  const INIT_FLAG = '__vibesMailchimpNewsletterAjax__';
  if (window[INIT_FLAG]) return;
  window[INIT_FLAG] = true;
  const JSONP_NAMESPACE = '__vibesMailchimpCallbacks__';
  if (!window[JSONP_NAMESPACE] || typeof window[JSONP_NAMESPACE] !== 'object') {
    window[JSONP_NAMESPACE] = {};
  }
  function clean(m) { return String(m).replace(/<[^>]*>/g,'').replace(/^\s*[01]\s*-\s*/,'').trim() || 'Something went wrong.'; }
  function jsonp(url, ms) {
    return new Promise((resolve, reject) => {
      const k = 'cb_' + Math.random().toString(36).slice(2);
      url.searchParams.set('c', JSONP_NAMESPACE + '.' + k);
      const s = document.createElement('script');
      s.src = url.toString();
      s.async = true;
      let done = false;
      const t = setTimeout(() => fin(new Error('Timeout')), ms);
      function fin(e, d) {
        if (done) return;
        done = true;
        clearTimeout(t);
        delete window[JSONP_NAMESPACE][k];
        s.remove();
        e ? reject(e) : resolve(d);
      }
      window[JSONP_NAMESPACE][k] = (d) => fin(null, d);
      s.onerror = () => fin(new Error('Network'));
      document.body.appendChild(s);
    });
  }
  function set(el, st, msg) {
    el.classList.remove('is-loading','is-success','is-error');
    el.textContent = msg;
    if (st) el.classList.add(st);
  }
  const form = document.getElementById('mc-embedded-subscribe-form');
  if (!(form instanceof HTMLFormElement)) return;
  const r = form.parentElement.querySelector('.featured-cta-response');
  const btn = form.querySelector('button[type="submit"]');
  let busy = false;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (busy) return;
    if (!form.checkValidity()) return form.reportValidity();
    busy = true; btn.disabled = true;
    set(r, 'is-loading', 'Sending …');
    try {
      const u = new URL(form.action);
      u.pathname = u.pathname.replace(/\/subscribe\/post\/?$/, '/subscribe/post-json');
      const fd = new FormData(form);
      for (const [k,v] of fd.entries()) {
        if (k === 'EMAIL' || k === 'SOURCE' || k.startsWith('b_')) u.searchParams.set(k, String(v));
      }
      const d = await jsonp(u, 10000);
      if (d && d.result === 'success') {
        set(r, 'is-success', 'Subscribed — check your inbox to confirm.');
        form.reset();
      } else {
        set(r, 'is-error', d && d.msg ? clean(d.msg) : 'Something went wrong.');
      }
    } catch(err) {
      set(r, 'is-error', 'Could not connect. Please try again.');
    } finally {
      busy = false; btn.disabled = false;
    }
  });
})();
</script>
