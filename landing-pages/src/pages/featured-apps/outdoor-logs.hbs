  .subscribe {
    margin: 56px 0 32px;
    padding: 28px 28px 24px;
    border: 1px solid var(--rule);
    background: var(--paper-soft);
    text-align: center;
  }
  .subscribe h2 {
    font-family: "Didot", "Bodoni MT", "Playfair Display", Georgia, serif;
    font-weight: 400;
    font-size: 24px;
    margin: 0 0 6px;
  }
  .subscribe p {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 15px;
  }
  .subscribe form {
    display: inline-flex;
    gap: 8px;
    max-width: 100%;
    flex-wrap: wrap;
    justify-content: center;
  }
  .subscribe input[type="email"] {
    padding: 10px 14px;
    border: 1px solid var(--rule);
    background: var(--paper);
