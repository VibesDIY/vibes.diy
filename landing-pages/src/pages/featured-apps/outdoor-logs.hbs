  .post-actions a:last-child { margin-right: 0; }
  .post-actions a.start-fresh {
    color: var(--rust);
    border-bottom-color: var(--rust);
    font-weight: 600;
  }
  .post-actions a.start-fresh:hover {
    background: var(--rust);
    color: var(--paper);
    border-bottom-color: var(--rust);
  }

  .prompt-figures {
    display: grid;
    gap: 8px;
    margin: 0 0 16px;
    grid-template-columns: 1fr;
  }
