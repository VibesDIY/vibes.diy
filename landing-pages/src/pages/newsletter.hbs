      </a>
      <a href="https://links.vibes.diy/homepage" class="cta-card cta-card--red">
        <h3>Start Building</h3>
        <p>Jump into vibes.diy and launch your first app.</p>
      </a>
    </div>

    <div class="color-stripe color-stripe--bottom">
      <div style="background: var(--red);"></div>
      <div style="background: var(--cyan);"></div>
      <div style="background: var(--yellow);"></div>
      <div style="background: var(--near-black);"></div>
      <div style="background: var(--red);"></div>
      <div style="background: var(--cyan);"></div>
    </div>
  </div>
</div>

<script>
(function () {
  const JSONP_NS = '__vibesMailchimpCallbacks__';
  if (!window[JSONP_NS]) window[JSONP_NS] = {};

  function normalizeMsg(msg) {
    return String(msg).replace(/<[^>]*>/g, '').replace(/^\s*[01]\s*-\s*/, '').trim()
      || 'Something went wrong. Please try again.';
  }

  function jsonp(url, ms) {
    return new Promise((resolve, reject) => {
      const key = 'cb_' + Math.random().toString(36).slice(2);
      const ref = JSONP_NS + '.' + key;
      url.searchParams.set('c', ref);
      const s = document.createElement('script');
      s.src = url.toString();
      let done = false;
      const tid = setTimeout(() => fin(new Error('timeout')), ms);
      function fin(err, data) {
        if (done) return; done = true;
        clearTimeout(tid);
        delete window[JSONP_NS][key];
        if (s.parentNode) s.parentNode.removeChild(s);
        err ? reject(err) : resolve(data);
      }
      window[JSONP_NS][key] = (d) => fin(null, d);
      s.onerror = () => fin(new Error('network error'));
      document.body.appendChild(s);
    });
  }

  function setRes(el, cls, msg) {
    el.className = 'form-response' + (cls ? ' ' + cls : '');
    el.textContent = msg;
  }

  const form = document.getElementById('mc-embedded-subscribe-form');
  if (!(form instanceof HTMLFormElement)) return;
  const resEl = form.parentElement.querySelector('.form-response');
  const btn = form.querySelector('button[type="submit"]');
  if (!resEl || !btn) return;

  let busy = false;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (busy) return;
    busy = true;
    btn.disabled = true;
    setRes(resEl, 'is-loading', 'Subscribing…');
    try {
      const url = new URL(form.action);
      url.pathname = url.pathname.replace(/\/subscribe\/post\/?$/, '/subscribe/post-json');
      new FormData(form).forEach((v, k) => {
        if (k === 'EMAIL' || k === 'SOURCE' || k.startsWith('b_')) url.searchParams.set(k, String(v));
      });
      const data = await jsonp(url, 10000);
      if (data && data.result === 'success') {
        setRes(resEl, 'is-success', 'Subscribed. Check your inbox to confirm.');
        form.reset();
      } else {
        setRes(resEl, 'is-error', data && data.msg ? normalizeMsg(data.msg) : 'Something went wrong. Please try again.');
      }
    } catch {
      setRes(resEl, 'is-error', 'Could not connect. Please try again.');
    } finally {
      busy = false;
      btn.disabled = false;
    }
  });
})();
</script>
