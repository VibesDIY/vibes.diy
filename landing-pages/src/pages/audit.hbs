  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #1A1A2E;
    --surface: rgba(255,255,240,0.04);
    --border: rgba(255,255,240,0.08);
    --ivory: #FFFFF0;
    --mint: #00C9A7;
    --dim: rgba(255,255,240,0.5);
  }

  body {
    font-family: 'Alte Haas Grotesk', Arial, sans-serif;
    background: var(--bg);
    color: var(--ivory);
    -webkit-font-smoothing: antialiased;
  }

  .mono { font-family: 'JetBrains Mono', monospace; }

  .page-header {
    padding: 3rem 2rem 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .page-header h1 {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 0.25rem;
  }
  .page-header p {
    color: var(--dim);
    font-size: 0.95rem;
  }
  .page-header .count {
    display: inline-block;
    background: var(--mint);
    color: var(--bg);
    font-weight: 800;
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  .group {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem 2rem;
  }
  .group-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--mint); }

  .card-img {
    position: relative;
    background: #111;
  }
  .card-img img {
    width: 100%;
    aspect-ratio: 1200/630;
    object-fit: cover;
    display: block;
  }
  .card-img .tier {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    backdrop-filter: blur(8px);
  }
  .tier-1 { background: rgba(0,201,167,0.8); color: var(--bg); }
  .tier-2 { background: rgba(254,221,0,0.8); color: var(--bg); }
  .tier-3 { background: rgba(255,255,240,0.15); color: var(--ivory); }

  .card-body {
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }
  .card-info h3 {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .card-info .slug {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--dim);
  }
  .card-info .page-from {
    font-size: 0.7rem;
    color: var(--dim);
    margin-top: 0.15rem;
  }

  .card-links {
    display: flex;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .card-links a {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-open {
    background: var(--mint);
    color: var(--bg);
  }
  .btn-open:hover { background: #00e0bb; }
  .btn-remix {
    background: rgba(255,255,240,0.1);
    color: var(--ivory);
  }
  .btn-remix:hover { background: rgba(255,255,240,0.2); }

  .refresh-note {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2rem 3rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--dim);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
    .card-body { flex-direction: column; align-items: flex-start; }
  }
</style>

