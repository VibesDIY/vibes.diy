<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  background: #f4f4f0;
  color: #1a1a1a;
  font-size: 14px;
  line-height: 1.5;
}

/* ── Topbar ── */
.topbar {
  position: sticky; top: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.6rem 1.25rem;
  background: #231F20; color: #FFFFF0;
  border-bottom: 2px solid #000;
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
}
.topbar a { color: inherit; text-decoration: none; opacity: 0.7; }
.topbar a:hover { opacity: 1; }
.topbar .sep { opacity: 0.35; margin: 0 0.4rem; }
.topbar-logo { height: 22px; width: auto; opacity: 0.85; vertical-align: middle; margin-right: 0.5rem; }

/* ── Wrap ── */
.wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1.25rem 5rem; }

/* ── Hero ── */
.hero { margin-bottom: 2rem; }
.hero h1 { font-size: 2rem; font-weight: 800; line-height: 1.1; margin-bottom: 0.35rem; }
.hero p { color: #666; font-size: 0.95rem; margin-bottom: 1.25rem; }

/* ── Filters ── */
.filter-row { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
.filter-row input {
  flex: 1; min-width: 180px;
  padding: 0.45rem 0.75rem;
  border: 2px solid #231F20; border-radius: 6px;
  font-size: 0.85rem; font-family: inherit; background: #FFFFF0;
}
.filter-row input:focus { outline: 2px solid #009ACE; outline-offset: 1px; }
.fbtn {
  padding: 0.4rem 0.8rem;
  border: 2px solid #231F20; border-radius: 6px;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  cursor: pointer; background: #FFFFF0; font-family: inherit;
  transition: background 0.1s, color 0.1s;
}
.fbtn.active { background: #231F20; color: #FFFFF0; }
.fbtn.stem.active { background: #0070c9; border-color: #0070c9; color: white; }
.fbtn.hum.active { background: #7b3fa0; border-color: #7b3fa0; color: white; }
.stats { font-size: 0.78rem; color: #888; margin-top: 0.4rem; }

/* ── Institutions ── */
.inst {
  margin-bottom: 1.5rem;
  border: 2px solid #231F20; border-radius: 10px; overflow: hidden;
  background: white;
}
.inst[hidden] { display: none; }

.inst-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0.65rem 1rem;
  background: #CCCDC8; border-bottom: 2px solid #231F20;
  flex-wrap: wrap; gap: 0.35rem;
}
.inst-name { font-weight: 700; font-size: 0.95rem; }
.inst-meta { font-size: 0.75rem; color: #555; }

/* ── Courses ── */
.courses { padding: 0.6rem; display: flex; flex-direction: column; gap: 0.4rem; }
.course {
  padding: 0.6rem 0.8rem;
  border: 1.5px solid rgba(35,31,32,0.12); border-radius: 7px; background: #FFFFF0;
}
.course[hidden] { display: none; }
.course-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.2rem; }
.course-title { font-weight: 600; font-size: 0.88rem; line-height: 1.3; }
.src { font-size: 0.72rem; color: #0070c9; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
.src:hover { text-decoration: underline; }
.course-meta { font-size: 0.72rem; color: #888; margin-bottom: 0.35rem; }
.tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
.tag {
  font-size: 0.67rem; padding: 0.12rem 0.4rem;
  background: rgba(35,31,32,0.06); border: 1px solid rgba(35,31,32,0.12);
  border-radius: 3px; color: #333;
}

/* ── Footer ── */
.footer { text-align: center; padding: 2rem 1rem; font-size: 0.78rem; color: #999; border-top: 1px solid #ccc; margin-top: 2rem; }
.footer a { color: inherit; }

/* ── Cluster links ── */
.cluster-links { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.4rem; }
.cluster-link {
  display: inline-flex; align-items: center; gap: 0.25rem;
  font-size: 0.68rem; font-weight: 600;
  padding: 0.18rem 0.5rem;
  background: rgba(0,112,201,0.08); border: 1px solid #0070c9;
  color: #0070c9; border-radius: 3px; text-decoration: none;
  transition: background 0.12s, color 0.12s;
}
.cluster-link:hover { background: #0070c9; color: white; }
.cluster-link::after { content: "→"; font-size: 0.6rem; opacity: 0.7; }

/* ── Course page links ── */
.course-title-link {
  color: inherit; text-decoration: none; font-weight: inherit;
}
.course-title-link:hover { text-decoration: underline; color: #0070c9; }
</style>

