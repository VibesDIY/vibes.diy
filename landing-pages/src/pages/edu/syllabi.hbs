<script>
(function(){
  var domain = 'all';
  function setDomain(d) {
    domain = d;
    ['all','stem','hum'].forEach(function(k){
      document.getElementById('btn-'+k).classList.toggle('active', k===d);
    });
    filterAll();
  }
  function filterAll() {
    var q = (document.getElementById('q').value||'').toLowerCase();
    var sections = document.querySelectorAll('.inst');
    var tc=0, ic=0;
    sections.forEach(function(sec){
      if (domain!=='all' && sec.dataset.domain!==domain){ sec.hidden=true; return; }
      var cards = sec.querySelectorAll('.course');
      var any=false;
      cards.forEach(function(c){
        var txt = (c.querySelector('.course-title').textContent+' '+c.dataset.dept+' '+c.dataset.topics).toLowerCase();
        var show = !q||txt.includes(q);
        c.hidden=!show;
        if(show){any=true;tc++;}
      });
      sec.hidden=!any;
      if(any) ic++;
    });
    document.getElementById('stats').textContent =
      'Showing '+tc+' course'+(tc!==1?'s':'')+' from '+ic+' institution'+(ic!==1?'s':'');
  }
  window.filterAll=filterAll; window.setDomain=setDomain;
})();

