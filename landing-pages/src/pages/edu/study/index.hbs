<style>
  @import url("https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700;800;900&display=optional");

  :root {
    --bg:      oklch(0.12 0.02 260);
    --surface: oklch(0.17 0.03 260);
    --edge:    oklch(0.27 0.03 260);
    --text:    oklch(0.93 0.01 260);
    --muted:   oklch(0.50 0.02 260);
    --lime:    oklch(0.88 0.18 130);
    --coral:   oklch(0.72 0.18 25);
    --amber:   oklch(0.84 0.16 75);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: var(--bg);
    background-image: radial-gradient(circle, oklch(0.22 0.03 260) 1px, transparent 1px);
    background-size: 24px 24px;
    color: var(--text);
    font-family: "Inter", system-ui, sans-serif;
    line-height: 1.55;
    min-height: 100vh;
  }
  a { color: inherit; text-decoration: none; }

  .layout {
    max-width: 1140px; margin: 0 auto; padding: 0 1.5rem;
    border-left: 1px solid var(--edge); border-right: 1px solid var(--edge);
    background: var(--bg);
  }

  .topbar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 0; border-bottom: 1px solid var(--edge);
  }
  .topbar .brand {
    font-family: "Space Mono", monospace; font-weight: 700;
    font-size: 1.1rem; letter-spacing: -0.01em;
  }
  .topbar .cluster-tag {
    font-family: "Space Mono", monospace; font-size: 0.6rem;
    letter-spacing: 0.14em; color: var(--muted);
  }
  .topbar .cluster-tag b { color: var(--lime); font-weight: 700; }

  .crumb {
    padding: 0.55rem 0; font-family: "Space Mono", monospace;
    font-size: 0.58rem; letter-spacing: 0.12em; color: var(--muted);
    border-bottom: 1px solid var(--edge);
  }
  .crumb a:hover { color: var(--text); }

  .hero {
    padding: 4rem 0 3.5rem; border-bottom: 1px solid var(--edge);
  }
  .hero-label {
    font-family: "Space Mono", monospace; font-size: 0.6rem;
    letter-spacing: 0.18em; color: var(--muted); margin-bottom: 1.75rem;
  }
  .hero h1 {
    font-family: "Space Mono", monospace; font-weight: 700;
    font-size: clamp(4rem, 11vw, 9rem);
    line-height: 0.90; letter-spacing: -0.025em; margin-bottom: 2rem;
  }
  .hero h1 .hl-lime  { color: var(--lime);  display: block; }
  .hero h1 .hl-coral { color: var(--coral); display: block; }
  .hero h1 .hl-amber { color: var(--amber); display: block; }
  .hero-sub {
    font-size: 1.05rem; max-width: 660px;
    color: oklch(0.75 0.01 260); line-height: 1.65; margin-bottom: 2rem;
  }
  .hero-meta {
    font-family: "Space Mono", monospace; font-size: 0.58rem;
    letter-spacing: 0.18em; color: var(--muted);
    border-top: 1px solid var(--edge); padding-top: 1rem;
  }

  /* cluster sections */
  .cluster { border-bottom: 1px solid var(--edge); padding: 2.5rem 0; }
  .sec-flash { --accent: var(--lime); }
  .sec-quiz  { --accent: var(--coral); }
  .sec-tools { --accent: var(--amber); }

  .cluster-head {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-bottom: 0.85rem; margin-bottom: 1.5rem;
    border-bottom: 2px solid var(--accent);
  }
  .ch-left { display: flex; align-items: baseline; gap: 0.75rem; }
  .ch-label {
    font-family: "Space Mono", monospace; font-weight: 700;
    font-size: 0.8rem; letter-spacing: 0.1em; color: var(--accent);
  }
  .ch-count {
    font-family: "Space Mono", monospace; font-size: 0.55rem;
    letter-spacing: 0.12em; color: var(--muted);
  }
  .ch-link {
    font-family: "Space Mono", monospace; font-size: 0.6rem;
    letter-spacing: 0.1em; color: var(--accent);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .ch-link:hover { opacity: 0.7; }

  /* grid */
  .app-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--edge);
  }

  /* card */
  .app-card {
    background: var(--surface);
    display: flex; flex-direction: column;
    position: relative; transition: outline 0.08s;
  }
  .app-card:hover { outline: 2px solid var(--accent); outline-offset: -1px; z-index: 1; }

  /* screenshot */
  .card-shot {
    display: block; aspect-ratio: 16/9; overflow: hidden;
    background: oklch(0.10 0.02 260);
  }
  .card-shot img { width: 100%; height: 100%; object-fit: cover; }
  .shot-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: "Space Mono", monospace; font-size: 0.55rem;
    letter-spacing: 0.18em; color: var(--muted); text-transform: uppercase;
  }

  /* card body */
  .card-body {
    padding: 1rem 1.1rem 0.85rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1;
  }
  .card-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.15rem; }
  .tag-badge {
    font-family: "Space Mono", monospace; font-weight: 700;
    font-size: 0.48rem; letter-spacing: 0.22em;
    padding: 2px 7px; background: var(--accent); color: var(--bg);
  }
  .card-num {
    font-family: "Space Mono", monospace; font-size: 0.52rem;
    letter-spacing: 0.15em; color: var(--muted);
  }
  .card-title {
    font-family: "Space Mono", monospace; font-weight: 700;
    font-size: 0.92rem; line-height: 1.3; color: var(--text);
  }
  .card-tagline {
    font-size: 0.78rem; color: var(--muted); line-height: 1.45; flex: 1;
  }

  /* buttons */
  .card-btns {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--edge); margin-top: auto;
  }
  .card-btns--single { grid-template-columns: 1fr; }
  .cbtn {
    text-align: center; padding: 0.5rem 0;
    border-right: 1px solid var(--edge);
    font-family: "Space Mono", monospace; font-size: 0.52rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); transition: background 0.1s, color 0.1s;
  }
  .cbtn:last-child { border-right: none; }
  .cbtn:hover { background: var(--accent); color: var(--bg); }

  /* footer */
  .foot {
    padding: 1.25rem 0;
    display: flex; justify-content: space-between; align-items: center;
    font-family: "Space Mono", monospace; font-size: 0.58rem;
    letter-spacing: 0.12em; color: var(--muted);
  }
  .foot a:hover { color: var(--text); }

  @media (max-width: 860px) {
    .app-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .app-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: clamp(3.5rem, 20vw, 5rem); }
  }
</style>

