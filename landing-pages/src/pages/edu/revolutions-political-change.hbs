<style>
  @import url("https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap");

  :root {
    --parchment: #F5F1E8;
    --ink: #1C1917;
    --purple: #6B3FA0;
    --purple-dim: rgba(107, 63, 160, 0.1);
    --muted: #706B63;
    --card: #FEFCF5;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: var(--parchment);
    color: var(--ink);
    font-family: "Inter", system-ui, sans-serif;
    line-height: 1.55;
  }

  a { color: inherit; text-decoration: none; }

  /* ── Topbar ── */
  .topbar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.65rem 1.25rem;
    background: var(--ink); color: var(--parchment);
    position: sticky; top: 0; z-index: 100;
  }
  .topbar-logo { height: 22px; width: auto; opacity: 0.85; vertical-align: middle; }
  .topbar-crumb {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase;
  }
  .topbar-crumb a { opacity: 0.6; }
  .topbar-crumb a:hover { opacity: 1; }
  .topbar-crumb .sep { margin: 0 0.35rem; opacity: 0.35; }

  /* ── Wrap ── */
  .wrap {
    max-width: 1040px; margin: 0 auto; padding: 0 1.5rem;
    border-left: 2px solid var(--ink); border-right: 2px solid var(--ink);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .cluster-hero {
    padding: 4rem 0 3rem;
    border-bottom: 4px solid var(--ink);
  }
  .dept-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--purple); margin-bottom: 0.9rem;
  }
  .cluster-hero h1 {
    font-family: "EB Garamond", Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700; line-height: 1.08; letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .cluster-desc {
    font-size: 1.05rem; color: var(--muted);
    max-width: 660px; margin-bottom: 1.75rem; line-height: 1.6;
  }
  .vocab-row { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .vocab-tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem; letter-spacing: 0.08em; text-transform: lowercase;
    padding: 0.22rem 0.55rem;
    background: var(--purple-dim); border: 1px solid var(--purple);
    color: var(--purple); border-radius: 3px;
  }

  /* ── Sources ── */
  .sources-block {
    padding: 1.5rem 0;
    border-bottom: 2px solid var(--ink);
  }
  .section-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 0.75rem;
  }
  .source-list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
  .source-list li { font-size: 0.85rem; display: flex; align-items: baseline; gap: 0.5rem; }
  .source-inst {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); white-space: nowrap;
  }
  .source-list a {
    color: var(--purple);
    text-decoration: underline;
    text-decoration-color: rgba(107,63,160,0.35);
  }
  .source-list a:hover { text-decoration-color: var(--purple); }

  /* ── App List ── */
  .apps-label {
    padding: 1.5rem 0 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--muted);
  }
  .app {
    display: grid; grid-template-columns: 3.5rem 1fr 300px; gap: 2rem;
    padding: 2.5rem 0; border-bottom: 2px solid var(--ink);
    transition: background 0.15s, padding 0.15s, margin 0.15s;
  }
  .app:hover {
    background: var(--purple-dim);
    padding-left: 1rem; padding-right: 1rem;
    margin-left: -1rem; margin-right: -1rem;
  }
  @media (max-width: 860px) {
    .app { grid-template-columns: 3rem 1fr; gap: 1.25rem; }
    .app .right { grid-column: 1 / -1; }
  }

  .num-cell { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding-top: 0.15rem; }
  .app-num {
    font-family: "EB Garamond", Georgia, serif;
    font-size: 2.2rem; font-weight: 700; color: var(--purple); line-height: 1;
  }
  .app-live {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.48rem; letter-spacing: 0.15em; text-transform: uppercase;
    background: var(--purple); color: white; padding: 2px 5px; border-radius: 2px;
  }

  .body { display: flex; flex-direction: column; gap: 0.55rem; }
  .body h2 {
    font-family: "EB Garamond", Georgia, serif;
    font-size: 1.75rem; font-weight: 700; line-height: 1.12;
  }
  .body .tagline {
    font-family: "EB Garamond", Georgia, serif;
    font-size: 1rem; color: var(--muted); font-style: italic;
  }
  .body .desc { font-size: 0.95rem; line-height: 1.65; color: var(--ink); }

  .right { display: flex; flex-direction: column; gap: 0.6rem; }
  .shot {
    display: block; aspect-ratio: 16/9; overflow: hidden;
    border: 2px solid var(--ink); background: var(--parchment);
  }
  .shot img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .shot:hover img { transform: scale(1.03); }
  .ctas {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border: 2px solid var(--ink);
  }
  .btn {
    display: block; text-align: center; padding: 0.55rem 0.25rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700;
    border-right: 1px solid var(--ink);
    transition: background 0.12s, color 0.12s;
  }
  .btn:last-child { border-right: none; }
  .btn:hover { background: var(--purple); color: white; }
  .prompt-link {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem; color: var(--muted); text-align: right;
  }
  .prompt-link:hover { color: var(--purple); text-decoration: underline; }

  /* ── Footer ── */
  .page-footer {
    padding: 2rem 0;
    display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
    border-top: 4px solid var(--ink);
  }
  .page-footer a { color: var(--purple); }
  .page-footer a:hover { text-decoration: underline; }
  .page-footer .sep { opacity: 0.3; }
</style>

