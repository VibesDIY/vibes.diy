  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { background: var(--parchment); color: var(--ink); font-family: "Inter", system-ui, sans-serif; line-height: 1.55; }
  a { color: inherit; text-decoration: none; }

  /* ── Topbar ── */
  .topbar { display: flex; justify-content: space-between; align-items: center; padding: 0.65rem 1.25rem; background: var(--ink); color: var(--parchment); position: sticky; top: 0; z-index: 100; }
  .topbar-logo { height: 22px; width: auto; opacity: 0.85; vertical-align: middle; }
  .topbar-crumb { font-family: "JetBrains Mono", monospace; font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; }
  .topbar-crumb a { opacity: 0.6; }
  .topbar-crumb a:hover { opacity: 1; }
  .topbar-crumb .sep { margin: 0 0.35rem; opacity: 0.35; }

  /* ── Wrap ── */
  .wrap { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; border-left: 2px solid var(--ink); border-right: 2px solid var(--ink); min-height: 100vh; }

  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3.5rem;
    border-bottom: 4px solid var(--ink);
    display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: end;
  }
  @media (max-width: 640px) { .hero { grid-template-columns: 1fr; } }
  .hero-label { font-family: "JetBrains Mono", monospace; font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--purple); margin-bottom: 0.9rem; }
  .hero h1 { font-family: "EB Garamond", Georgia, serif; font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.01em; margin-bottom: 1rem; }
  .hero-desc { font-size: 1.05rem; color: var(--muted); max-width: 560px; line-height: 1.6; }
  .hero-stat {
    text-align: right;
    font-family: "EB Garamond", Georgia, serif;
  }
  .hero-stat .big { font-size: 3.5rem; font-weight: 700; line-height: 1; color: var(--purple); }
  .hero-stat .label { font-size: 0.85rem; color: var(--muted); font-style: italic; }

  /* ── Section headers ── */
  .section-header {
    padding: 2rem 0 1.25rem;
    border-bottom: 2px solid var(--ink);
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap;
  }
  .section-title { font-family: "JetBrains Mono", monospace; font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--muted); }
  .section-count { font-family: "JetBrains Mono", monospace; font-size: 0.6rem; color: var(--muted); }

