  @media (max-width: 760px) { .cluster-card:nth-child(3n) { border-right: 2px solid var(--ink); } .cluster-card:nth-child(2n) { border-right: none; } }
  .cluster-card:hover { background: var(--purple-dim); }

  .cc-dept { font-family: "JetBrains Mono", monospace; font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
  .cc-title { font-family: "EB Garamond", Georgia, serif; font-size: 1.25rem; font-weight: 700; line-height: 1.2; margin-bottom: 0.6rem; }
  .cc-vocab { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 0.9rem; }
  .cc-tag { font-family: "JetBrains Mono", monospace; font-size: 0.55rem; letter-spacing: 0.06em; padding: 0.18rem 0.45rem; background: var(--purple-dim); border: 1px solid var(--purple); color: var(--purple); border-radius: 3px; }
  .cc-cta { font-family: "JetBrains Mono", monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--purple); font-weight: 700; }
