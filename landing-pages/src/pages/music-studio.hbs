<style>
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=optional");

  :root {
    --bg:          oklch(0.12 0.012 40);
    --bg-elev:     oklch(0.18 0.015 40);
    --bg-deep:     oklch(0.09 0.010 35);
    --fg:          oklch(0.96 0.005 60);
    --fg-dim:      oklch(0.62 0.012 60);
    --fg-faint:    oklch(0.38 0.010 55);
    --border:      oklch(1 0 0 / 0.08);
    --border-hi:   oklch(1 0 0 / 0.18);
    --amber:       oklch(0.82 0.17 72);
    --amber-text:  oklch(0.12 0.04 55);
    --blue:        oklch(0.70 0.17 225);
    --blue-text:   oklch(0.10 0.04 225);
    --red:         oklch(0.62 0.22 22);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    font-family: "Inter", system-ui, sans-serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.55;
    min-height: 100vh;
    background-image:
      radial-gradient(circle at 6% 0%, rgba(200, 130, 40, 0.07), transparent 35%),
      radial-gradient(circle at 96% 98%, rgba(60, 140, 200, 0.07), transparent 42%);
    background-attachment: fixed;
  }

  a { color: inherit; text-decoration: none; }

  .layout { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── TOPBAR ── */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .brand::before { content: "▶ "; color: var(--amber); }
  .brand:hover { color: var(--amber); }
  .pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid var(--border-hi);
    border-radius: 999px;
    color: var(--fg-dim);
  }
  .pill .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 8px var(--amber);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 50% { opacity: 0.3; } }

  .crumb {
    padding: 0.55rem 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    border-bottom: 1px solid var(--border);
  }
  .crumb a:hover { color: var(--amber); }

  /* ── HERO ── */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }
  .hero .kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
  }
  .hero .kicker::before { content: "// "; opacity: 0.5; }
  .hero h1 {
    font-size: clamp(2.8rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
  }
  .hero h1 .aa { color: var(--amber); }
  .hero h1 .ab { color: var(--blue); }
  .hero .lede {
    font-size: 1.15rem;
    max-width: 680px;
    color: var(--fg);
    opacity: 0.82;
    line-height: 1.65;
  }
  .hero .lede strong { color: var(--amber); font-weight: 600; }
  .hero .lede a {
    color: var(--amber);
    border-bottom: 1px solid rgba(200, 130, 40, 0.4);
    transition: border-color 0.15s;
  }
  .hero .lede a:hover { border-color: var(--amber); }

  /* ── STATS ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin: 3rem 0;
  }
  @media (max-width: 640px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat-cell {
    padding: 1.5rem;
    border-right: 1px solid var(--border);
  }
  .stat-cell:last-child { border-right: none; }
  @media (max-width: 640px) {
    .stat-cell:nth-child(2n) { border-right: none; }
    .stat-cell { border-bottom: 1px solid var(--border); }
    .stat-cell:nth-child(3), .stat-cell:nth-child(4) { border-bottom: none; }
  }
  .sk {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin-bottom: 0.35rem;
  }
  .sv {
    font-weight: 900;
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--amber);
  }
  .sv.blue { color: var(--blue); }
  .sv.small {
    font-size: 1.2rem;
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    color: var(--fg-dim);
  }

  /* ── SECTION HEAD ── */
  .section-wrap {
    padding: 3.5rem 0 4rem;
  }
  .section-head { margin-bottom: 2.5rem; }
  .section-kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .sk-amber { color: var(--amber); }
  .sk-blue  { color: var(--blue); }
  .section-head h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 0.95;
    margin-bottom: 0.9rem;
  }
  .section-head p {
    font-size: 1rem;
    color: var(--fg-dim);
    max-width: 56ch;
    line-height: 1.65;
  }

  /* ── APP GRID ── */
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) { .app-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .app-grid { grid-template-columns: 1fr; } }

  /* ── APP CARD ── */
  .app-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .app-card--orig:hover {
    border-color: rgba(200, 130, 40, 0.5);
    box-shadow: 0 0 0 1px rgba(200, 130, 40, 0.15), 0 4px 24px rgba(200, 130, 40, 0.10);
  }
  .app-card--remix:hover {
    border-color: rgba(60, 140, 200, 0.5);
    box-shadow: 0 0 0 1px rgba(60, 140, 200, 0.12), 0 4px 24px rgba(60, 140, 200, 0.10);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem 0;
  }
  .card-badge {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    font-weight: 700;
  }
  .badge-orig  { background: rgba(200, 130, 40, 0.14); color: var(--amber); border: 1px solid rgba(200, 130, 40, 0.32); }
  .badge-remix { background: rgba(60, 140, 200, 0.12); color: var(--blue);  border: 1px solid rgba(60, 140, 200, 0.30); }
  .card-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    color: var(--fg-faint);
  }

  /* ── SCREENSHOT ── */
  .card-shot {
    margin: 0.75rem 1rem;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
    aspect-ratio: 16 / 9;
    background: var(--bg-deep);
    position: relative;
    flex-shrink: 0;
  }
  .card-shot img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .shot-soon {
    position: absolute; inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }
  .shot-soon-glyph {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.75rem;
    color: var(--blue);
    opacity: 0.4;
  }
  .shot-soon-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--fg-faint);
  }

  /* ── CARD BODY ── */
  .card-body { padding: 0 1rem; flex: 1; }
  .card-title {
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.3rem;
  }
  .card-tagline {
    font-size: 0.78rem;
    color: var(--fg-dim);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }
  .card-desc {
    font-size: 0.74rem;
    color: var(--fg-faint);
    line-height: 1.72;
    margin-bottom: 1rem;
  }

  /* ── CARD ACTIONS ── */
  .card-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding: 0 1rem 1rem;
  }
  .btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.57rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.38rem 0.8rem;
    border-radius: 3px;
    border: 1px solid transparent;
    cursor: pointer;
    line-height: 1;
    transition: all 0.14s;
    display: inline-block;
  }
  .btn-join  { background: var(--amber); color: var(--amber-text); font-weight: 700; }
  .btn-join:hover  { opacity: 0.85; }
  .btn-clone { border-color: var(--border-hi); color: var(--fg-dim); }
  .btn-clone:hover { border-color: var(--fg-dim); color: var(--fg); }
  .btn-remix { border-color: rgba(60, 140, 200, 0.4); color: var(--blue); }
  .btn-remix:hover { background: rgba(60, 140, 200, 0.1); }
  .btn-soon {
    background: transparent;
    border-color: var(--border);
    color: var(--fg-faint);
    cursor: default;
    pointer-events: none;
  }

  /* ── FORK HINT ── */
  .card-fork {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    line-height: 1.65;
    color: var(--fg-faint);
    border-left: 2px solid rgba(200, 130, 40, 0.4);
    padding: 0 1rem 0 0.85rem;
    margin: 0 1rem 0.75rem;
  }

  /* ── PROMPT BLOCK ── */
  .prompt-block {
    margin: 0 1rem 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-deep);
    overflow: hidden;
    font-size: 0.75rem;
  }
  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.44rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: rgba(200, 130, 40, 0.06);
  }
  .prompt-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .copy-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    background: rgba(255,255,255,0.06);
    border: none;
    border-radius: 2px;
    color: var(--fg-faint);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .copy-btn:hover { background: var(--amber); color: var(--amber-text); }
  .copy-btn.copied { background: var(--amber); color: var(--amber-text); }

  .prompt-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.67rem;
    line-height: 1.65;
    color: var(--fg-dim);
    white-space: pre-wrap;
    word-break: break-word;
    padding: 0.75rem;
    display: block;
  }

  /* expandable spec */
  .prompt-details summary {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.57rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
    padding: 0.55rem 0.75rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.12s;
    user-select: none;
  }
  .prompt-details summary:hover { color: var(--fg); }
  .prompt-details summary::before { content: "▸"; transition: transform 0.15s; display: inline-block; }
  .prompt-details[open] summary::before { transform: rotate(90deg); }
  .prompt-details summary::-webkit-details-marker { display: none; }

  /* ── REMIX BANNER ── */
  .remix-banner {
    background: var(--bg-deep);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0;
  }
  .remix-banner-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  @media (max-width: 700px) {
    .remix-banner-inner { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
  }
  .remix-banner-label {
    font-size: clamp(2.2rem, 5.5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--blue);
    flex-shrink: 0;
    line-height: 1;
  }
  .remix-banner-desc {
    font-size: 0.9rem;
    color: var(--fg-dim);
    line-height: 1.68;
    max-width: 54ch;
  }
  .remix-banner-desc strong { color: var(--blue); font-weight: 600; }

  /* ── CTA ── */
  .cta-wrap { padding: 5rem 0; }
  .cta-block {
    background: var(--bg-elev);
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    padding: 3.5rem 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 0.75rem;
  }
  .cta-block h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .cta-block p {
    font-size: 0.9rem;
    color: var(--fg-dim);
    max-width: 44ch;
    line-height: 1.68;
  }
  .cta-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; flex-shrink: 0; }
  .btn-cta-primary {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.75rem 1.5rem;
    background: var(--amber);
    color: var(--amber-text);
    border: none;
    border-radius: 4px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.14s;
    display: inline-block;
  }
  .btn-cta-primary:hover { opacity: 0.85; }
  .btn-cta-ghost {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.7rem 1.25rem;
    background: transparent;
    color: var(--fg-dim);
    border: 1px solid var(--border-hi);
    border-radius: 4px;
    transition: border-color 0.14s, color 0.14s;
    display: inline-block;
  }
  .btn-cta-ghost:hover { border-color: var(--fg-dim); color: var(--fg); }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-copy {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.08em;
    color: var(--fg-faint);
  }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    transition: color 0.14s;
  }
  .footer-links a:hover { color: var(--amber); }
</style>

<!-- TOPBAR -->
