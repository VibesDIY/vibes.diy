    font-size: 0.8rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  /* ── Statline ── */
  .statline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    background: var(--paper-2);
  }
  @media (max-width: 700px) { .statline { grid-template-columns: repeat(2, 1fr); } }
  .stat-cell {
    padding: 1.2rem 1.4rem;
    border-right: 1px solid var(--rule);
  }
  .stat-cell:last-child { border-right: none; }
  @media (max-width: 700px) {
    .stat-cell { border-bottom: 1px solid var(--rule); }
    .stat-cell:nth-child(2n) { border-right: none; }
    .stat-cell:nth-last-child(-n+2) { border-bottom: none; }
  }
  .stat-cell .k {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }
  .stat-cell .v {
    font-family: "Playfair Display", serif;
    font-weight: 900;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  /* ── Section header ── */
  .section-hdr {
    padding: 2.6rem 0 0.6rem;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .section-hdr h2 {
    font-family: "Playfair Display", serif;
    font-weight: 900;
    font-size: 2rem;
    letter-spacing: -0.015em;
  }
  .section-hdr .label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Gallery ── */
  .apps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    padding: 1.5rem 0 3.5rem;
  }
  @media (max-width: 900px) { .apps { grid-template-columns: 1fr; } }

  .app {
    background: #fffbf2;
    border: 1.5px solid var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    padding: 1.8rem;
    display: flex; flex-direction: column; gap: 0.9rem;
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .app:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--regulatory-red);
  }
  .app .head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--rule);
  }
  .app .num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
  }
  .app .status {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--muted);
    border-radius: 2px;
    color: var(--muted);
    font-weight: 600;
  }
  .app--live .status {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .app--pending .status {
    border-color: var(--regulatory-red);
    color: var(--regulatory-red);
  }
  .app .title {
    font-family: "Playfair Display", serif;
    font-weight: 900;
    font-size: 1.9rem;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .app .tagline {
    font-style: italic;
    font-size: 1rem;
    color: var(--regulatory-red);
    line-height: 1.4;
  }
  .app .desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--ink-soft);
    flex: 1;
  }
  .app .shot {
    display: block;
    aspect-ratio: 16/10;
    overflow: hidden;
    border: 1.5px solid var(--ink);
    background: var(--paper-2);
  }
  .app .shot img { width: 100%; height: 100%; object-fit: cover; }
  .app .shot-placeholder {
    height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    padding: 1rem;
  }
  .app .ctas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .app .ctas--single { grid-template-columns: 1fr; }
  .btn {
    text-align: center;
    padding: 0.7rem 0.5rem;
    background: transparent;
    border: 1.5px solid var(--ink);
    border-radius: 2px;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
    transition: all .12s;
  }
  .btn:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .btn-remix:hover {
    background: var(--regulatory-red);
    border-color: var(--regulatory-red);
  }
  .prompt-link {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .prompt-link:hover { color: var(--regulatory-red); }

  /* ── Editorial epilogue ── */
  .epilogue {
    margin: 1rem 0 3rem;
    padding: 2.6rem 2.2rem;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
  }
  .epilogue h2 {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
