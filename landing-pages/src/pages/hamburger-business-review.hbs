  .filing-card .stamp-corner {
    position: absolute;
    top: -14px; right: 18px;
    background: var(--paper);
    color: var(--regulatory-red);
    border: 2px solid var(--regulatory-red);
    padding: 4px 10px;
    font-weight: 700;
