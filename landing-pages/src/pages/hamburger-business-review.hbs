<style>
  @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=optional");

  :root {
    --paper: #f5efe2;
    --paper-2: #ede5d4;
    --ink: #1a1814;
    --ink-soft: #3a342a;
    --muted: #807663;
    --rule: #1a181433;
    --regulatory-red: #b3261e;
    --regulatory-red-soft: #b3261e22;
    --ledger-gold: #8a6a1b;
    --accent-stamp: #b3261e;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    background: var(--paper);
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(26,24,20,0.04) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(26,24,20,0.04) 40px);
    color: var(--ink);
    font-family: "Inter", system-ui, sans-serif;
    line-height: 1.55;
    min-height: 100vh;
  }
  a { color: var(--ink); text-decoration: none; }
  a:hover { color: var(--regulatory-red); }

  .display { font-family: "Playfair Display", "Times New Roman", serif; font-weight: 900; letter-spacing: -0.01em; }
  .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }

  .layout { max-width: 1180px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── Masthead ── */
  .masthead {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 1.2rem 0 0.8rem;
    border-bottom: 2px solid var(--ink);
  }
