  .game-card .info p {
    font-size: 0.85rem; color: var(--muted); line-height: 1.5;
    margin-bottom: 1rem;
  }
  .game-card .info .tag {
    display: inline-block;
    font-family: "Press Start 2P", monospace;
    font-size: 0.45rem; letter-spacing: 0.1em; text-transform: uppercase;
