  }
  .hero .badge {
    display: inline-block;
    font-family: "Press Start 2P", monospace;
    font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--yellow);
    border: 1px solid rgba(255, 215, 0, 0.3);
    padding: 5px 12px; border-radius: 4px;
    margin-bottom: 1.5rem;
    background: rgba(255, 215, 0, 0.08);
  }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900; line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .hero h1 .hi { color: var(--accent); }
  .hero h1 .blocks { color: var(--yellow); }
  .hero .lead {
    font-size: 1.2rem; max-width: 640px; margin: 0 auto 2.5rem;
    color: rgba(255, 255, 255, 0.7); line-height: 1.6;
  }
  .hero .cta-row {
