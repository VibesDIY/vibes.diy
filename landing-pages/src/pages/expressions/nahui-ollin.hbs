<style>
  @import url("https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=optional");

  :root {
    --obsidian:      #06040a;
    --stone:         #12100a;
    --stone-elevated:#1e1a10;
    --stone-border:  #2a2015;
    --fg:            #d4c5a0;
    --fg-muted:      #8a7a60;
    --gold:          #c9a84c;
    --gold-glow:     rgba(201,168,76,0.25);
    --terracotta:    #c0522a;
    --terra-glow:    rgba(192,82,42,0.25);
    --jade:          #00c9a7;
    --jade-glow:     rgba(0,201,167,0.25);
    --crimson:       #b03030;
    --crimson-glow:  rgba(176,48,48,0.25);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    font-family: "Cormorant Garamond", Georgia, serif;
    background: var(--obsidian);
    color: var(--fg);
    line-height: 1.65;
    min-height: 100vh;
  }

  a { color: var(--fg); text-decoration: none; }
  p a, li a { text-decoration: underline; }

  h1, h2, h3 { font-family: "Cinzel", serif; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  /* ---- CROWN BAR ---- */
  .crown-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--stone-border), var(--gold), var(--terracotta), var(--gold), var(--stone-border));
  }

  /* ---- TOPBAR ---- */
  .topbar {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--stone-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--stone);
  }
  .topbar .brand {
    font-family: "Cinzel", serif;
    font-weight: 700;
    letter-spacing: 0.2em;
    font-size: 0.85rem;
    color: var(--gold);
    text-shadow: 0 0 10px var(--gold-glow);
  }
  .topbar .sigils { font-size: 1rem; color: var(--fg-muted); letter-spacing: 0.4em; }

  /* ---- BREADCRUMB ---- */
  .crumb {
    padding: 0.6rem 1.5rem;
    border-bottom: 1px solid var(--stone-border);
    font-family: "Cinzel", serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .crumb a { color: var(--fg-muted); }
  .crumb a:hover { color: var(--gold); }

  /* ---- HERO ---- */
  .hero {
    padding: 4rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--stone-border);
  }
  .hero .label {
    font-family: "Cinzel", serif;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 1.75rem;
  }
  .hero h1 {
    font-family: "Cinzel Decorative", "Cinzel", serif;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1.05;
    color: var(--gold);
    text-shadow: 0 0 30px var(--gold-glow);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }
  .hero .subtitle {
    font-family: "Cinzel", serif;
    font-size: clamp(0.7rem, 1.5vw, 0.9rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 1.5rem;
  }
  .hero .divider { color: var(--gold); margin: 1.5rem 0; letter-spacing: 0.5em; }
  .hero p {
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--fg);
    max-width: 660px;
    margin: 0 auto;
  }

  /* ---- STATS ---- */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--stone-border);
  }
  @media (max-width: 700px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat-cell {
    padding: 1.25rem 1.5rem;
    border-right: 1px solid var(--stone-border);
  }
  .stat-cell:last-child { border-right: none; }
  .stat-cell .k {
    font-family: "Cinzel", serif;
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }
  .stat-cell .v {
    font-family: "Cinzel", serif;
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-shadow: 0 0 12px var(--gold-glow);
  }

  /* ---- SECTION LABELS ---- */
  .section-label {
    padding: 1.75rem 0 0.75rem;
    font-family: "Cinzel", serif;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
  }
  .section-label--gold { color: var(--gold); }
  .section-label--jade { color: var(--jade); }
  .section-label::before { content: "◈  "; }

  /* ---- APP CARDS ---- */
  .apps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    padding: 1rem 0 3rem;
  }
  @media (max-width: 800px) { .apps { grid-template-columns: 1fr; } }

  /* Accent variant: set --accent-color and --accent-glow on the card */
  .app--gold    { --accent-color: var(--gold);       --accent-glow: var(--gold-glow);    }
  .app--terracotta { --accent-color: var(--terracotta); --accent-glow: var(--terra-glow); }
  .app--crimson { --accent-color: var(--crimson);    --accent-glow: var(--crimson-glow); }
  .app--jade    { --accent-color: var(--jade);       --accent-glow: var(--jade-glow);    }

  .app {
    background: var(--stone);
    border: 1px solid var(--stone-border);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .app:hover {
    border-color: var(--accent-color);
    box-shadow: 0 0 32px var(--accent-glow);
    background: var(--stone-elevated);
  }

  .app .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--stone-border);
  }
  .app .num {
    font-family: "Cinzel", serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .app .status {
    font-family: "Cinzel", serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--fg-muted);
    color: var(--fg-muted);
  }
  .app--live .status {
    background: var(--accent-color);
    border-color: var(--accent-color);
    color: var(--obsidian);
  }

  .app .title {
    font-family: "Cinzel", serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    text-shadow: 0 0 18px var(--accent-glow);
  }
  .app .tagline {
    font-style: italic;
    font-size: 1.05rem;
    color: var(--fg);
  }
  .app .desc {
    font-size: 0.98rem;
    color: var(--fg);
    flex: 1;
  }

  .app .shot {
    display: block;
    aspect-ratio: 16/10;
    overflow: hidden;
    border: 1px solid var(--stone-border);
    background: var(--obsidian);
  }
  .app .shot img { width: 100%; height: 100%; object-fit: cover; }
  .app .shot-placeholder {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Cinzel", serif;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--fg-muted);
    text-align: center;
    padding: 1rem;
  }

  .app .ctas { display: flex; gap: 0.4rem; }
  .btn {
    flex: 1;
    text-align: center;
    padding: 0.55rem 0.5rem;
    background: transparent;
    border: 1px solid var(--fg-muted);
    font-family: "Cinzel", serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
    cursor: pointer;
    transition: all .15s;
    text-decoration: none;
    display: block;
  }
  .btn:hover {
    background: var(--accent-color);
    border-color: var(--accent-color);
    color: var(--obsidian);
    box-shadow: 0 0 20px var(--accent-glow);
  }
  .prompt-link {
    font-style: italic;
    color: var(--fg-muted);
    font-size: 0.92rem;
  }
  .prompt-link:hover { color: var(--accent-color); }

  /* ---- DIVIDER ---- */
  .codex-divider {
    border: none;
    border-top: 1px solid var(--stone-border);
    text-align: center;
    margin: 0;
    overflow: visible;
    line-height: 0;
  }
  .codex-divider::after {
    content: "◈";
    display: inline-block;
    background: var(--obsidian);
    padding: 0 0.75rem;
    font-size: 0.85rem;
    color: var(--gold);
    position: relative;
    top: -0.45rem;
  }

  /* ---- EPILOGUE ---- */
  .epilogue {
    padding: 2.5rem 0 2rem;
    border-top: 1px solid var(--stone-border);
  }
  .epilogue h2 {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 1rem;
  }
  .epilogue p {
    font-style: italic;
    font-size: 1.1rem;
    max-width: 720px;
    color: var(--fg);
  }

  /* ---- FOOTER ---- */
  footer.term-footer {
    padding: 1.5rem;
    border-top: 1px solid var(--stone-border);
    text-align: center;
    font-family: "Cinzel", serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-muted);
    background: var(--stone);
  }
  footer.term-footer a { color: var(--fg-muted); }
  footer.term-footer a:hover { color: var(--gold); }
</style>

<div class="crown-bar"></div>

<header class="topbar">
  <span class="brand">VIBES.DIY</span>
