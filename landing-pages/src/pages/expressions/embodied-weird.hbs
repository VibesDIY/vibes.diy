    {"num":"03","slug":"side-eye-cam","author":"jchris","live":true,"title":"Side-Eye Cam","tagline":"Detects glance toward phone, logs the cadence.","desc":"Local face-tracking only. An embodied diary of when you can't help looking. SIDE-EYES PER HOUR rolls up across days."},
    {"num":"04","slug":"phone-flipped","author":"jchris","live":true,"title":"Phone-Flipped Status","tagline":"Face-down on the table = busy.","desc":"Device-orientation API toggles your status to BUSY. Friends see a rune-grid roster — glow when present, dim when face-down."},
