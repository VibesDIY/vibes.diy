      <div class="card-ctas">
        <a class="cta-btn primary" href="https://vibes.diy/vibe/og/event-info-page" target="_blank" rel="noopener">Open</a>
        <a class="cta-btn" href="https://vibes.diy/remix/og/event-info-page?skipChat=true" target="_blank" rel="noopener">Clone</a>
