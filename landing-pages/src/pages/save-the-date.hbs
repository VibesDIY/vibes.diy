             onerror="this.onerror=null; this.src='{{assetPrefix}}images/og-preview.png';">
      </a>
      <div class="card-body">
        <div class="card-num">App 05</div>
        <h3 class="card-title">Event Countdown Clock</h3>
        <p class="card-tagline">The big day, ticking closer. Share it so everyone feels the same urgency you do.</p>
        <p class="card-fork">Countdown to the rehearsal dinner or bachelor party instead? Clone and set the date.</p>
