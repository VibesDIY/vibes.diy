<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=optional');

  :root {
    --warm-bg: #faf5ef;
    --warm-surface: #fff9f4;
    --warm-deep: #2c1810;
    --warm-mid: #5c4033;
    --warm-muted: #8a7060;
    --warm-line: #e8ddd2;
    --gold: #c4944a;
    --gold-soft: rgba(196, 148, 74, 0.12);
    --gold-hover: #a87b3a;
    --blush: #f0e4d8;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--warm-deep);
    line-height: 1.56;
    background: var(--warm-bg);
  }

  a { color: inherit; text-decoration: none; }

  .page { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem 4rem; }

  /* Nav */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--warm-line);
    font-size: 0.85rem;
  }

  .brand {
    display: flex; align-items: center; gap: 0.6rem;
    font-weight: 800; letter-spacing: 0.02em;
  }

  .brand img { height: 28px; width: auto; display: block; }

  .nav-right { color: var(--warm-muted); font-weight: 600; font-size: 0.8rem; }

  /* Hero */
  .hero {
    padding: 3.5rem 0 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; gap: 1.5rem; padding: 2.5rem 0 2rem; }
  }

  .hero-text h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 800;
    line-height: 1.06;
    margin-bottom: 1rem;
    color: var(--warm-deep);
  }

  .hero-text h1 em {
    font-style: normal;
    color: var(--gold);
  }

  .hero-lead {
    font-size: 1.05rem;
    color: var(--warm-mid);
    max-width: 480px;
    margin-bottom: 1.5rem;
    line-height: 1.65;
  }

  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    font-weight: 700;
    font-size: 0.88rem;
    border-radius: 8px;
    padding: 0.85rem 1.5rem;
    transition: background 0.12s;
  }

  .hero-cta:hover { background: var(--gold-hover); }

  .hero-visual {
    position: relative;
  }

  .hero-screenshot {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--warm-line);
    box-shadow: 0 12px 40px rgba(44, 24, 16, 0.1);
    display: block;
  }

  .hero-photo {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    border: 4px solid var(--warm-bg);
    box-shadow: 0 4px 16px rgba(44, 24, 16, 0.15);
  }

  @media (max-width: 760px) {
    .hero-photo { width: 100px; height: 100px; bottom: -10px; right: -4px; }
  }

  /* Value strip */
  .value-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--warm-line);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  @media (max-width: 600px) { .value-strip { grid-template-columns: 1fr; } }

  .value-cell {
    background: var(--warm-surface);
    padding: 1.25rem 1.2rem;
    text-align: center;
  }

  .value-cell strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--warm-deep);
  }

  .value-cell span {
    font-size: 0.84rem;
    color: var(--warm-muted);
    line-height: 1.45;
  }

  /* Apps section */
  .apps-header {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--warm-muted);
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--warm-line);
  }

  /* Spotlight app */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--warm-surface);
    border: 1px solid var(--warm-line);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 12px rgba(44, 24, 16, 0.04);
  }

  @media (max-width: 700px) {
    .spotlight { grid-template-columns: 1fr; }
    .spotlight-shot { order: -1; }
  }

  .spotlight-body {
    padding: 2rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
  }

  .spotlight-num {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 700;
  }

  .spotlight-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--warm-deep);
  }

  .spotlight-tagline {
    font-size: 0.95rem;
    color: var(--warm-mid);
    line-height: 1.55;
  }

  .spotlight-fork {
    font-size: 0.82rem;
    color: var(--gold);
    font-style: italic;
  }

  .spotlight-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .btn-gold {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    transition: background 0.12s;
  }

  .btn-gold:hover { background: var(--gold-hover); }

  .btn-outline {
    display: inline-block;
    background: transparent;
    color: var(--warm-mid);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--warm-line);
    transition: background 0.12s;
  }

  .btn-outline:hover { background: var(--gold-soft); }

  .spotlight-shot a {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 260px;
  }

  .spotlight-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 260px;
  }

  /* App card grid */
  .apps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 640px) { .apps-grid { grid-template-columns: 1fr; } }

  .app-card {
    background: var(--warm-surface);
    border: 1px solid var(--warm-line);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(44, 24, 16, 0.03);
    transition: transform 0.12s, box-shadow 0.12s;
  }

  .app-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(44, 24, 16, 0.08);
  }

  .app-card .shot-wrap {
    display: block;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-bottom: 1px solid var(--warm-line);
    background: var(--blush);
  }

  .app-card .shot-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-num {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 700;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--warm-deep);
    line-height: 1.2;
  }

  .card-tagline {
    font-size: 0.88rem;
    color: var(--warm-muted);
    line-height: 1.5;
  }

  .card-fork {
    font-size: 0.8rem;
    color: var(--gold);
    font-style: italic;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .card-ctas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--warm-line);
    margin-top: auto;
  }

  .cta-btn {
    text-align: center;
    padding: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--warm-mid);
    transition: background 0.12s;
  }

  .cta-btn:first-child { border-right: 1px solid var(--warm-line); }
  .cta-btn:hover { background: var(--gold-soft); }
  .cta-btn.primary { color: var(--gold); }
  .cta-btn.primary:hover { background: var(--gold-soft); }

  /* Closing CTA */
  .closing {
    background: var(--warm-deep);
    color: var(--warm-bg);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    text-align: center;
  }

  .closing h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .closing p {
    font-size: 1rem;
    opacity: 0.85;
    max-width: 520px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .btn-light {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    font-weight: 700;
    font-size: 0.88rem;
    border-radius: 8px;
    padding: 0.85rem 2rem;
    transition: background 0.12s;
  }

  .btn-light:hover { background: var(--gold-hover); }

  /* Footer */
  .page-footer {
    padding: 1.5rem 0 0;
    margin-top: 2rem;
    border-top: 1px solid var(--warm-line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--warm-muted);
    transition: color 0.12s;
  }

  .footer-links a:hover { color: var(--gold); }

  .footer-copy {
    font-size: 0.7rem;
    color: var(--warm-muted);
  }
</style>

<div class="page">
  <header class="topbar">
