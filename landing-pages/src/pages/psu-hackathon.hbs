<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  reveals.forEach(el => observer.observe(el));

  // YouTube lite embed
  document.querySelectorAll('.yt-facade').forEach(facade => {
    facade.addEventListener('click', () => {
      const id = facade.dataset.videoId;
      if (id) {
        facade.innerHTML = `<iframe src="https://www.youtube.com/embed/${id}?autoplay=1&rel=0" title="vibetoken.lol" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
      }
    });
  });
</script>
