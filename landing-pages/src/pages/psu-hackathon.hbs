<style>
  @import url('https://fonts.cdnfonts.com/css/alte-haas-grotesk');

  :root {
    --black: #000000;
    --near-black: #231f20;
    --gray-dark: #333333;
    --gray-mid: #6b6b6b;
    --gray-light: #cccdc8;
    --cream: #fffff0;
    --red: #da291c;
    --cyan: #009ace;
    --yellow: #fedd00;

    --font-main: 'Alte Haas Grotesk', -apple-system, 'Segoe UI', sans-serif;
    --card-border: 2px solid var(--black);
    --gutter: clamp(1rem, 4vw, 3rem);
    --grid-size: 40px;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background-color: #cccdc8;
    background-image:
      linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px);
    background-size: var(--grid-size) var(--grid-size);
    color: var(--near-black);
    font-family: var(--font-main);
    font-size: clamp(1rem, 1.1vw, 1.125rem);
    line-height: 1.6;
    overflow-x: hidden;
  }

  ::selection { background: var(--yellow); color: var(--black); }
  a { color: var(--red); text-decoration: underline; text-underline-offset: 2px; transition: color 0.2s; }
  a:hover { color: var(--black); }
  h1, h2, h3 { font-family: var(--font-main); font-weight: normal; line-height: 1.1; }

  /* Nav */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0.75rem var(--gutter);
    display: flex; justify-content: space-between; align-items: center;
    background: var(--cream); border-bottom: 3px solid var(--black);
  }
  .nav-logo { text-decoration: none; display: flex; align-items: center; }
  .nav-logo-pill { height: 36px; width: auto; display: block; transition: opacity 0.2s; }
  .nav-logo:hover .nav-logo-pill { opacity: 0.85; }
  .nav-cta-btn {
    background: var(--red); color: var(--cream) !important;
    padding: 0.5rem 1.2rem; text-decoration: none !important;
    font-weight: bold; font-size: 0.85rem; border: 2px solid var(--black);
    transition: background 0.2s, transform 0.15s;
  }
  .nav-cta-btn:hover { background: var(--near-black); transform: translateY(-1px); }

  /* Page */
  .page {
    max-width: 860px; margin: 0 auto;
    padding: calc(60px + 2.5rem) var(--gutter) 3rem;
  }

  /* Color stripe */
  .color-stripe { height: 8px; display: flex; margin-bottom: 1.5rem; }
  .color-stripe > div { flex: 1; }

  /* Cards */
  .card {
    background: var(--cream); border: var(--card-border);
    padding: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 1.5rem;
  }
  .card--red    { background: var(--red);    color: var(--cream); }
  .card--cyan   { background: var(--cyan);   color: var(--cream); }
  .card--yellow { background: var(--yellow); color: var(--black); }
  .card--black  { background: var(--black);  color: var(--cream); }

  /* Hero */
  .event-badge {
    display: inline-block; font-size: 0.7rem; font-weight: bold;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.3rem 0.75rem; border: 2px solid var(--black);
    margin-bottom: 1rem; background: var(--yellow);
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.02em; line-height: 1.05;
    margin-bottom: 1rem;
  }
  .event-meta {
    display: flex; flex-direction: column; gap: 0.3rem;
    font-size: clamp(1rem, 1.8vw, 1.2rem); color: var(--gray-dark);
    margin-bottom: 1.5rem;
  }
  .event-meta strong { color: var(--near-black); }

  /* CTA button */
  .btn-primary {
    display: inline-block; padding: 1rem 2rem;
    background: var(--red); color: var(--cream) !important;
    font-family: var(--font-main); font-size: 1.1rem; font-weight: bold;
    text-decoration: none !important; border: 2px solid var(--black);
    box-shadow: 4px 4px 0 var(--black);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--black); color: var(--cream) !important; }

  .btn-secondary {
    display: inline-block; padding: 1rem 2rem;
    background: var(--cream); color: var(--near-black) !important;
    font-family: var(--font-main); font-size: 1.1rem; font-weight: bold;
    text-decoration: none !important; border: 2px solid var(--black);
    box-shadow: 4px 4px 0 var(--black);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-secondary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--black); }

  /* YouTube lite embed */
  .yt-facade {
    position: relative; width: 100%; aspect-ratio: 16/9;
    overflow: hidden; cursor: pointer; background: var(--near-black);
    border: var(--card-border);
  }
  .yt-facade img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .yt-play-btn {
    position: absolute; inset: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.2); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .yt-facade:hover .yt-play-btn { background: rgba(0,0,0,0.35); }
  .yt-facade iframe {
    position: absolute; inset: 0; width: 100%; height: 100%; border: 0;
  }

  /* Section label */
  .section-label {
    display: inline-block; font-size: 0.7rem; font-weight: bold;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.3rem 0.75rem; border: 2px solid currentColor;
    margin-bottom: 0.75rem;
  }

  /* Prize card */
  .prize-number {
    font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: bold;
    line-height: 1; margin-bottom: 0.25rem;
  }

  /* Grid */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }

  /* QR section */
  .qr-wrap {
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem; padding: 2rem;
    background: var(--cream); border: var(--card-border);
    margin-bottom: 1.5rem; text-align: center;
  }
  .qr-wrap img { display: block; width: 200px; height: 200px; image-rendering: pixelated; }
  .qr-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-mid); }
  .qr-url { font-size: 0.9rem; font-weight: bold; color: var(--near-black); }

  /* Footer */
  footer { margin-top: 1.5rem; padding: 2rem var(--gutter); text-align: center; font-size: 0.8rem; color: var(--near-black); }
  footer a { color: var(--red); margin: 0 0.75rem; text-decoration: none; }
  footer a:hover { text-decoration: underline; }
  .footer-logo { height: 40px; width: auto; }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(14px); transition: opacity 0.45s ease, transform 0.45s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 600px) {
    .grid-2 { grid-template-columns: 1fr; }
    nav .nav-cta-btn { display: none; }
  }
</style>

