<style>
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap");

  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{
    font-family:'Inter', system-ui, sans-serif;
    background:#ffffff;
    color:#121212;
    min-height:100vh;
    background-image:radial-gradient(circle at 10% 10%, #f9df74 0 80px, transparent 81px), radial-gradient(circle at 90% 30%, #a0c35a 0 90px, transparent 91px), radial-gradient(circle at 30% 90%, #b0c4ef 0 100px, transparent 101px), radial-gradient(circle at 80% 80%, #a374d5 0 70px, transparent 71px);
    background-attachment:fixed;
  }
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1100px;margin:0 auto;padding:64px 24px 96px;position:relative;z-index:1}
  header.top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:48px;gap:24px;flex-wrap:wrap}
  header.top a.back{color:#121212;text-decoration:none;opacity:.6;font-size:14px}
  header.top a.back:hover{opacity:1}
  h1{font-family:'Inter', sans-serif;font-size:clamp(40px,7vw,84px);margin:0;line-height:.95;letter-spacing:-.02em}
  .desc{max-width:560px;font-size:18px;opacity:.75;margin:16px 0 0}
  .accent-bar{display:inline-block;height:6px;width:120px;background:#a374d5;margin:24px 0 0}
  .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px;margin-top:56px}
  @media (max-width:720px){.grid{grid-template-columns:1fr}}
  .card{background:#f4eef9;border:none;border-radius:12px;box-shadow:0 6px 24px rgba(20,20,40,.08);overflow:hidden;display:flex;flex-direction:column;transition:transform .15s ease}
  .card:hover{transform:translateY(-2px)}
  .shot{display:block;aspect-ratio:16/10;background:#ffffff;overflow:hidden}
  .shot img{width:100%;height:100%;object-fit:cover;display:block}
  .meta{padding:20px 22px 24px}
  .meta h3{margin:0 0 10px;font-size:24px;letter-spacing:-.01em}
  .meta h3 a{color:inherit;text-decoration:none}
  .meta h3 a:hover{color:#a374d5}
  .prompt{margin:0 0 16px;font-size:14px;line-height:1.55;opacity:.78}
  .play{display:inline-flex;align-items:center;gap:6px;color:#a374d5;font-weight:700;text-decoration:none;font-size:14px;letter-spacing:.02em}
  .play:hover{text-decoration:underline}
  footer{margin-top:64px;font-size:13px;opacity:.5}
</style>

