<style>
  @import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Sans+3:wght@400;700&display=swap");

  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{
    font-family:'Source Sans 3', system-ui, sans-serif;
    background:#fffdf3;
    color:#1a1a1a;
    min-height:100vh;
    background-image:radial-gradient(circle at 50% 50%, rgba(247,216,58,.15) 0 8px, transparent 9px) 0 0 / 36px 32px, radial-gradient(circle at 50% 50%, rgba(247,216,58,.15) 0 8px, transparent 9px) 18px 16px / 36px 32px;
    background-attachment:fixed;
  }
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1100px;margin:0 auto;padding:64px 24px 96px;position:relative;z-index:1}
  header.top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:48px;gap:24px;flex-wrap:wrap}
  header.top a.back{color:#1a1a1a;text-decoration:none;opacity:.6;font-size:14px}
  header.top a.back:hover{opacity:1}
  h1{font-family:'Bebas Neue', 'Source Sans 3', sans-serif;font-size:clamp(40px,7vw,84px);margin:0;line-height:.95;letter-spacing:-.02em}
  .desc{max-width:560px;font-size:18px;opacity:.75;margin:16px 0 0}
  .accent-bar{display:inline-block;height:6px;width:120px;background:#f7d83a;margin:24px 0 0}
  .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px;margin-top:56px}
  @media (max-width:720px){.grid{grid-template-columns:1fr}}
  .card{background:#fff8d3;border:3px solid #1a1a1a;border-radius:14px;box-shadow:0 4px 0 #1a1a1a;overflow:hidden;display:flex;flex-direction:column;transition:transform .15s ease}
  .card:hover{transform:translateY(-2px)}
  .shot{display:block;aspect-ratio:16/10;background:#fffdf3;overflow:hidden;border-bottom:3px solid #1a1a1a}
  .shot img{width:100%;height:100%;object-fit:cover;display:block}
  .meta{padding:20px 22px 24px}
  .meta h3{margin:0 0 10px;font-family:'Bebas Neue', 'Source Sans 3', sans-serif;font-size:24px;letter-spacing:-.01em}
  .meta h3 a{color:inherit;text-decoration:none}
  .meta h3 a:hover{color:#c9a800}
  .prompt{margin:0 0 16px;font-size:14px;line-height:1.55;opacity:.78}
  .play{display:inline-flex;align-items:center;gap:6px;color:#c9a800;font-weight:700;text-decoration:none;font-size:14px;letter-spacing:.02em}
  .play:hover{text-decoration:underline}
  footer{margin-top:64px;font-size:13px;opacity:.5}
</style>

