  <h2 class="section-title">Function signature</h2>

  <div class="cmd cmd--ts">
    (doc, oldDoc, user: UserContext | null, ctx: Helpers) => AccessDescriptor;
  </div>

  <table class="api-table">
    <thead>
      <tr><th>Argument</th><th>Description</th></tr>
