# OpenRouter API key for integration tests
# Get your API key from https://openrouter.ai/
CALLAI_API_KEY=your_openrouter_api_key_here

# Alternatively, you can use CALLAI_API_KEY which is also supported
# CALLAI_API_KEY=your_api_key_here

# Default model IDs (overridable per environment — see issue #1474).
# Each falls back to the value shown when unset.
# CALLAI_DEFAULT_MODEL=openrouter/auto    # default when no options.model is given
# CALLAI_FALLBACK_MODEL=openrouter/auto   # retry model when the primary model fails
# CALLAI_SCHEMA_MODEL=openai/gpt-4o       # default for schema/structured-output calls
