{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/node-hook-runner.sh\" \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/privacy-block.cjs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/node-hook-runner.sh\" \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/dangerous-cmd-block.cjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/node-hook-runner.sh\" \"$CLAUDE_PROJECT_DIR/.claude/skills/autoresearch/hooks/privacy-block.cjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
