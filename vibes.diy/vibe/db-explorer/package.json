{
  "name": "@vibes.diy/vibe-db-explorer",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "sync:css": "node ./scripts/sync-shared-css.js",
    "check:css": "node ./scripts/sync-shared-css.js --check",
    "dev": "node ./scripts/sync-shared-css.js && vite",
    "build": "node ./scripts/sync-shared-css.js && core-cli tsc && vite build",
    "pack": "node ./scripts/sync-shared-css.js && core-cli build --doPack",
    "publish": "node ./scripts/sync-shared-css.js && core-cli build"
  },
  "dependencies": {
    "@adviser/cement": "^0.5.34",
    "@fireproof/use-fireproof": "0.24.13",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.13",
    "@types/react-dom": "~19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.0"
  }
}
