{
  "name": "use-vibes",
  "version": "0.0.0",
  "type": "module",
  "description": "Transform any DOM element into an AI-powered micro-app",
  "bin": {
    "use-vibes": "./bin.js"
  },
  "scripts": {
    "build": "core-cli tsc",
    "test": "vitest run",
    "test:cli": "pnpm --dir ../tests run test:cli",
    "check:cli": "pnpm exec eslint ./dispatcher.ts ./cli/ ./commands/ ../tests/cli/",
    "pack": "core-cli build -x '^' --doPack",
    "publish": "core-cli build -x '^'"
  },
  "keywords": [
    "ai",
    "dom",
    "micro-app",
    "generator",
    "web",
    "esm",
    "typescript"
  ],
  "contributors": [
    "J Chris Anderson",
    "Meno Abels"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@adviser/cement": "^0.5.32",
    "find-up": "^8.0.0",
    "cmd-ts": "^0.15.0",
    "@vibes.diy/prompts": "workspace:*",
    "@fireproof/core": "0.24.12",
    "@fireproof/core-keybag": "0.24.12",
    "@fireproof/core-runtime": "0.24.12",
    "@fireproof/core-types-base": "0.24.12",
    "@fireproof/core-types-protocols-cloud": "0.24.12",
    "@fireproof/use-fireproof": "0.24.12",
    "@vibes.diy/use-vibes-base": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.1.0"
  },
  "devDependencies": {
    "@fireproof/core-cli": "0.24.12",
    "@vitest/browser-playwright": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
