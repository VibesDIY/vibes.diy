{
  "name": "@vibes.diy/use-vibes-cli",
  "version": "0.0.0",
  "type": "module",
  "description": "Transform any DOM element into an AI-powered micro-app",
  "bin": {
    "use-vibes": "run.js"
  },
  "scripts": {
    "build": "core-cli tsc",
    "run": "node run.js",
    "test": "vitest run",
    "pack": "core-cli build -x '^' --doPack",
    "publish": "core-cli build -x '^'"
  },
  "keywords": [
    "ai",
    "dom",
    "micro-app",
    "generator",
    "web",
    "esm",
    "typescript"
  ],
  "contributors": [
    "J Chris Anderson",
    "Meno Abels"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@adviser/cement": "^0.5.33",
    "@fireproof/core": "0.24.12",
    "@fireproof/core-device-id": "0.24.12",
    "@fireproof/core-keybag": "0.24.12",
    "@fireproof/core-protocols-dashboard": "0.24.12",
    "@fireproof/core-runtime": "0.24.12",
    "@fireproof/core-types-base": "0.24.12",
    "@fireproof/core-types-protocols-cloud": "0.24.12",
    "@fireproof/core-types-protocols-dashboard": "0.24.12",
    "@fireproof/use-fireproof": "0.24.12",
    "@vibes.diy/api-impl": "workspace:*",
    "@vibes.diy/api-types": "workspace:*",
    "arktype": "^2.1.29",
    "cmd-ts": "^0.14.3",
    "jose": "^6.2.1",
    "tsx": "^4.21.0",
    "undici": "^7.23.0",
    "ws": "^8.19.0",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@fireproof/core-cli": "0.24.12",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
